# Azure AD App Registration — vyplň po dokončení krokov v README.md
# Hodnoty AZURE_CLIENT_ID, AZURE_TENANT_ID a AZURE_CLIENT_SECRET poskytne IT administrátor
# AZURE_USER_EMAIL je tvoj vlastný @inovia.sk e-mail

# Application (client) ID z Azure Portal > App registrations > Overview
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Directory (tenant) ID z Azure Portal > App registrations > Overview
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client secret z Azure Portal > App registrations > Certificates & secrets
AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tvoj Microsoft 365 e-mail (napr. jan.novak@inovia.sk)
AZURE_USER_EMAIL=meno.priezvisko@inovia.sk
